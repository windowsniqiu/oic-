rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Reuseable global helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Admin Collection
    match /admins/{adminId} {
      // First admin can register, subsequent admin creations require existing admin approval or is owner
      allow read: if true;
      allow create: if isSignedIn() && request.auth.uid == adminId;
      allow update, delete: if isAdmin() && request.auth.uid == adminId;
    }

    // Settings Collection
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Posts Collection
    match /posts/{postId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
